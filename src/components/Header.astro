---
import siteConfig from '../../site.config.mjs';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 bg-cream/95 backdrop-blur-sm border-b border-beige shadow-sm"
  style="height: var(--header-h); z-index: 10000;"
>
  <div class="max-w-6xl mx-auto px-6 h-full flex items-center justify-between">
    <a href="/" class="font-display text-2xl" aria-label={`${siteConfig.name} – accueil`}>
      <span class="text-teal">{siteConfig.logoPrefix}</span><span class="text-terracotta">{siteConfig.logoSuffix}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 font-body text-sm font-medium">
      <a href="/" class="text-dark/70 hover:text-teal transition-colors">Accueil</a>
      <a href="/blog" class="text-dark/70 hover:text-teal transition-colors">Blog</a>
      {siteConfig.shop?.enabled && <a href="/boutique" class="text-dark/70 hover:text-teal transition-colors">Boutique</a>}
      {siteConfig.shop?.enabled && (
        <button class="snipcart-checkout text-dark/70 hover:text-teal transition-colors inline-flex items-center gap-1.5 relative" aria-label="Voir le panier">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="snipcart-items-count text-xs font-semibold"></span>
        </button>
      )}
      <a href="/#a-propos" class="btn-primary">À propos</a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="md:hidden p-2 rounded-lg text-dark"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="hidden md:hidden bg-cream border-t border-beige px-6 py-4 flex-col gap-4 font-body text-sm font-medium"
  >
    <a href="/" class="block py-2 text-dark/70 hover:text-teal transition-colors">Accueil</a>
    <a href="/blog" class="block py-2 text-dark/70 hover:text-teal transition-colors">Blog</a>
    {siteConfig.shop?.enabled && <a href="/boutique" class="block py-2 text-dark/70 hover:text-teal transition-colors">Boutique</a>}
    {siteConfig.shop?.enabled && (
      <button class="snipcart-checkout block py-2 text-dark/70 hover:text-teal transition-colors text-left">
        Panier (<span class="snipcart-items-count">0</span>)
      </button>
    )}
    <a href="/#a-propos" class="btn-primary mt-2 justify-center">À propos</a>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('mobile-nav');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden', isOpen);
    nav?.classList.toggle('flex', !isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
